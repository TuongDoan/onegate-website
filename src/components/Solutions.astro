---
const items = [
  { title: 'Structured Search', desc: 'A cleaner way to explore products across a complex supply market.' },
  { title: 'Smarter Filtering', desc: 'Find better-fit options with clearer product and supplier filtering.' },
  { title: 'Connected Workflow', desc: 'Move from discovery to order tracking through one integrated journey' },
  { title: 'Documentation Ready', desc: 'Support business purchases with a more documentation-ready process.' },
];
---

<section class="solutions" id="solutions">
  <div class="solutions__inner">
    <h2 class="solutions__title">Our<br />Solutions</h2>

    <ul class="solutions__list">
      {items.map((it) => (
        <li class="solutions__item">
          <h3 class="solutions__heading">{it.title}</h3>
          <p class="solutions__desc">{it.desc}</p>
        </li>
      ))}
    </ul>

    <div class="solutions__image-wrap">
      <img src="/img/solutions.jpg" alt="Online shopping on mobile" class="solutions__image" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .solutions {
    background: #FFFFFF;
    padding: 6rem 3.5rem;
  }

  .solutions__inner {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .solutions__title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    font-weight: 400;
    color: var(--forest);
    line-height: 1.05;
    letter-spacing: -0.015em;
  }

  .solutions__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .solutions__item {}

  .solutions__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--forest);
    margin-bottom: 0.75rem;
  }

  .solutions__desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: #3a3a3a;
    max-width: 440px;
  }

  .solutions__image-wrap {
    display: flex;
    justify-content: center;
  }

  .solutions__image {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }

  @media (max-width: 960px) {
    .solutions { padding: 4rem 1.5rem; }
    .solutions__inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
