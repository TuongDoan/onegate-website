---
---

<section class="contact" id="contact">
  <div class="contact__inner">
    <div class="contact__info">
      <span class="contact__tag">Get In Touch</span>
      <h2 class="contact__title">Ready to Open Your<br/>Global Gateway?</h2>
      <p class="contact__text">
        Tell us about your trade needs and we'll connect you with the right team.
        Expect a response within one business day.
      </p>
      <div class="contact__details">
        <div class="contact__detail">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 2C6.24 2 4 4.24 4 7c0 4.5 5 9 5 9s5-4.5 5-9c0-2.76-2.24-5-5-5z" stroke="#18442A" stroke-width="1.5"/>
            <circle cx="9" cy="7" r="2" stroke="#18442A" stroke-width="1.5"/>
          </svg>
          <span>Ho Chi Minh City, Vietnam</span>
        </div>
        <div class="contact__detail">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M2 4h14v10a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke="#18442A" stroke-width="1.5"/>
            <path d="M2 4l7 7 7-7" stroke="#18442A" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>info@onegate.global</span>
        </div>
        <div class="contact__detail">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3 3h3l1.5 4-2 1.5a10 10 0 005 5L12 11l4 1.5V16a1 1 0 01-1 1A14 14 0 012 4a1 1 0 011-1z" stroke="#18442A" stroke-width="1.5"/>
          </svg>
          <span>+84 28 1234 5678</span>
        </div>
      </div>
    </div>

    <form class="contact__form">
      <div class="contact__row">
        <div class="contact__field">
          <label for="name">Full Name</label>
          <input id="name" type="text" placeholder="John Smith" />
        </div>
        <div class="contact__field">
          <label for="company">Company</label>
          <input id="company" type="text" placeholder="Acme Corp" />
        </div>
      </div>
      <div class="contact__field">
        <label for="email">Email Address</label>
        <input id="email" type="email" placeholder="john@acme.com" />
      </div>
      <div class="contact__field">
        <label for="service">Service Needed</label>
        <select id="service">
          <option value="">Select a service…</option>
          <option>Trade Sourcing</option>
          <option>Freight Forwarding</option>
          <option>Customs & Compliance</option>
          <option>Warehousing</option>
          <option>Supply Chain Consulting</option>
          <option>Other</option>
        </select>
      </div>
      <div class="contact__field">
        <label for="message">Message</label>
        <textarea id="message" rows="4" placeholder="Tell us about your requirements…"></textarea>
      </div>
      <button type="submit" class="contact__submit">Send Enquiry</button>
    </form>
  </div>
</section>

<style>
  .contact {
    padding: 7rem 2rem;
    background: var(--off-white);
  }

  .contact__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: start;
  }

  .contact__tag {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--forest);
    background: rgba(24, 68, 42, 0.08);
    padding: 0.35rem 1rem;
    border-radius: 50px;
    margin-bottom: 1.25rem;
  }

  .contact__title {
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 800;
    color: #0f1f15;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .contact__text {
    font-size: 0.95rem;
    line-height: 1.75;
    color: #555;
    margin-bottom: 2rem;
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact__detail {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Raleway', sans-serif;
    font-size: 0.9rem;
    color: #444;
    font-weight: 500;
  }

  /* Form */
  .contact__form {
    background: white;
    border-radius: 24px;
    padding: 2.5rem;
    border: 1px solid rgba(24, 68, 42, 0.07);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .contact__field label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: #444;
    letter-spacing: 0.04em;
  }

  .contact__field input,
  .contact__field select,
  .contact__field textarea {
    font-family: 'Raleway', sans-serif;
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border: 1.5px solid rgba(24, 68, 42, 0.15);
    border-radius: 10px;
    background: var(--off-white);
    color: #222;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
    appearance: none;
  }

  .contact__field input:focus,
  .contact__field select:focus,
  .contact__field textarea:focus {
    border-color: var(--forest);
    background: white;
  }

  .contact__field input::placeholder,
  .contact__field textarea::placeholder {
    color: #bbb;
  }

  .contact__submit {
    padding: 0.9rem 2rem;
    background: var(--forest);
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.25rem;
  }

  .contact__submit:hover {
    background: var(--leaf);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(24, 68, 42, 0.25);
  }

  @media (max-width: 900px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .contact__row {
      grid-template-columns: 1fr;
    }
  }
</style>
