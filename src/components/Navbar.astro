<nav class="navbar" id="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">
      <img src="/logo.svg" alt="One Gate Global Trading" class="navbar__logo-img" />
    </a>

    <ul class="navbar__links">
      <li><a href="#about">About Us</a></li>
      <li><a href="#solutions">Our Solutions</a></li>
    </ul>

    <a href="#cta" class="navbar__cta">Talk to Us</a>

    <button class="navbar__burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(24, 68, 42, 0.07);
  }

  .navbar__inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .navbar__logo-img {
    height: 36px;
    width: auto;
  }

  .navbar__links {
    display: flex;
    list-style: none;
    gap: 2.5rem;
    margin-left: auto;
  }

  .navbar__links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .navbar__links a:hover {
    color: var(--forest);
  }

  .navbar__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.5rem;
    background: var(--forest);
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
  }

  .navbar__cta:hover {
    background: var(--leaf);
    transform: translateY(-1px);
  }

  .navbar__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .navbar__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--forest);
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .navbar__links { display: none; }
    .navbar__cta { display: none; }
    .navbar__burger { display: flex; }
  }
</style>
