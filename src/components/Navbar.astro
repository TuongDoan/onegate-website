<nav class="navbar" id="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">
      <img src="/logo.svg" alt="One Gate Global Trading" class="navbar__logo-img" />
    </a>

    <ul class="navbar__links">
      <li><a href="#about">About Us</a></li>
      <li><a href="#solutions">Our Solutions</a></li>
    </ul>

    <button class="navbar__burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
  }

  .navbar__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 2rem 3.5rem;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .navbar__logo-img {
    height: 53px;
    width: auto;
    display: block;
  }

  .navbar__links {
    display: flex;
    list-style: none;
    gap: 3rem;
    margin-left: auto;
  }

  .navbar__links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.96rem;
    font-weight: 500;
    color: var(--forest);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .navbar__links a:hover { opacity: 0.65; }

  .navbar__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .navbar__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--forest);
    border-radius: 2px;
  }

  @media (max-width: 720px) {
    .navbar__inner { padding: 1.25rem 1.25rem; }
    .navbar__links { display: none; }
    .navbar__burger { display: flex; }
  }
</style>
