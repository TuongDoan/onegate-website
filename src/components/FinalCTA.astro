<section class="cta" id="cta">
  <div class="cta__inner">
    <h2 class="cta__title">Talk to One Gate</h2>
    <a href="mailto:info@onegate.global" class="cta__btn">Talk to Us</a>
  </div>
</section>

<style>
  .cta {
    padding: 10rem 2.5rem;
    background: white;
    text-align: center;
  }

  .cta__inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .cta__title {
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-weight: 800;
    color: #0c1c12;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2.8rem;
    background: var(--forest);
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .cta__btn:hover {
    background: var(--leaf);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(24, 68, 42, 0.24);
  }
</style>
