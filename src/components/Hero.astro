---
---

<section class="hero">
  <img src="/img/banner.jpg" alt="" class="hero__map" aria-hidden="true" />

  <div class="hero__content">
    <h1 class="hero__title">
      Your Gateway<br />
      to China's<br />
      Sourcing Power
    </h1>
    <a href="#cta" class="hero__cta">TALK TO US</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    aspect-ratio: 1440 / 810;
    min-height: 640px;
    overflow: hidden;
    background: #EDE8DC;
  }

  .hero__map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    user-select: none;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 3.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 2.25rem;
  }

  .hero__title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--forest);
    letter-spacing: -0.015em;
  }

  .hero__cta {
    display: inline-block;
    padding: 1.1rem 3.25rem;
    background: var(--forest);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .hero__cta:hover {
    background: var(--leaf);
    transform: translateY(-2px);
  }

  @media (max-width: 720px) {
    .hero { min-height: 560px; aspect-ratio: auto; padding: 6rem 0 3rem; }
    .hero__map { opacity: 0.35; }
    .hero__content { padding: 0 1.5rem; }
  }
</style>
