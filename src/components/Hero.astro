---
---

<section class="hero">
  <!-- Full-viewport Leaflet map -->
  <div id="hero-map"></div>

  <!-- Gradient overlay for text legibility -->
  <div class="hero__overlay"></div>

  <!-- Content layer -->
  <div class="hero__content">
    <div class="hero__content-inner">
      <h1 class="hero__title">
        Your Gateway to<br />
        <em>Smarter China Sourcing</em>
      </h1>
      <p class="hero__subtitle">
        Unlock efficient sourcing from China with stronger cost control,
        better-fit supplier selection, and cross-border compliance built
        into the process.
      </p>
      <a href="#cta" class="hero__cta">Talk to Us</a>
    </div>
  </div>

  <!-- Floating cards — right side over the map -->
  <div class="hero__cards">
    <div class="hero__card">
      <div class="hero__card-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="6.5" stroke="#18442A" stroke-width="1.4"/>
          <path d="M8 1.5c0 0-3.5 2.5-3.5 6.5s3.5 6.5 3.5 6.5M8 1.5c0 0 3.5 2.5 3.5 6.5s-3.5 6.5-3.5 6.5M1.5 8h13" stroke="#18442A" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <strong>Vast Supply Access</strong>
        <span>A broader supply market, within reach</span>
      </div>
    </div>
    <div class="hero__card">
      <div class="hero__card-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M2 4h12M2 8h9M2 12h6" stroke="#18442A" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <strong>Smoother Procurement</strong>
        <span>A more structured sourcing journey</span>
      </div>
    </div>
    <div class="hero__card">
      <div class="hero__card-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="3" width="12" height="10" rx="2" stroke="#18442A" stroke-width="1.4"/>
          <path d="M5 8l2 2 4-4" stroke="#18442A" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div>
        <strong>Commercial Readiness</strong>
        <span>A business-ready transaction flow</span>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero__scroll">
    <div class="hero__scroll-line"></div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  const map = L.map('hero-map', {
    zoomControl: false,
    scrollWheelZoom: false,
    dragging: false,
    touchZoom: false,
    doubleClickZoom: false,
    boxZoom: false,
    keyboard: false,
    attributionControl: true,
  }).setView([25, 108], 4);

  // CartoDB Positron — clean, light, premium
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; <a href="https://carto.com/">CARTO</a> &copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>',
    subdomains: 'abcd',
    maxZoom: 19,
  }).addTo(map);

  // Custom pulsing marker factory
  function makeMarker(color: string, size = 14) {
    return L.divIcon({
      className: '',
      html: `
        <div style="position:relative;width:${size}px;height:${size}px">
          <div style="
            position:absolute;inset:0;border-radius:50%;
            background:${color};
            box-shadow:0 0 0 0 ${color}66;
            animation:map-pulse 2.5s ease-out infinite;
          "></div>
        </div>
      `,
      iconSize: [size, size],
      iconAnchor: [size / 2, size / 2],
    });
  }

  // Trade route: Shanghai → Hanoi (with intermediate arc points)
  const route: [number, number][] = [
    [31.2, 121.5],  // Shanghai
    [28.0, 118.5],
    [24.5, 114.0],
    [22.0, 111.0],
    [21.0, 107.5],  // Near Hanoi
    [21.0, 105.8],  // Hanoi
  ];

  L.polyline(route, {
    color: '#18442A',
    weight: 2.5,
    opacity: 0.85,
    dashArray: '8 5',
    lineCap: 'round',
  }).addTo(map);

  // Secondary route: Guangzhou → Ho Chi Minh City
  const route2: [number, number][] = [
    [23.1, 113.3],  // Guangzhou
    [20.0, 110.5],
    [16.5, 107.5],
    [10.8, 106.7],  // Ho Chi Minh City
  ];

  L.polyline(route2, {
    color: '#45644A',
    weight: 1.8,
    opacity: 0.6,
    dashArray: '6 5',
    lineCap: 'round',
  }).addTo(map);

  // Markers
  L.marker([31.2, 121.5], { icon: makeMarker('#18442A', 16) })
    .addTo(map)
    .bindTooltip('Shanghai', { permanent: true, direction: 'top', className: 'map-label' });

  L.marker([23.1, 113.3], { icon: makeMarker('#18442A', 14) })
    .addTo(map)
    .bindTooltip('Guangzhou', { permanent: true, direction: 'top', className: 'map-label' });

  L.marker([39.9, 116.4], { icon: makeMarker('#18442A', 12) })
    .addTo(map)
    .bindTooltip('Beijing', { permanent: true, direction: 'top', className: 'map-label' });

  L.marker([21.0, 105.8], { icon: makeMarker('#45644A', 16) })
    .addTo(map)
    .bindTooltip('Hanoi', { permanent: true, direction: 'right', className: 'map-label map-label--dest' });

  L.marker([10.8, 106.7], { icon: makeMarker('#45644A', 14) })
    .addTo(map)
    .bindTooltip('Ho Chi Minh City', { permanent: true, direction: 'right', className: 'map-label map-label--dest' });
</script>

<style>
  /* Inject pulse animation + map label styles */
  :global(.map-label) {
    background: white !important;
    border: 1px solid rgba(24, 68, 42, 0.2) !important;
    border-radius: 6px !important;
    padding: 2px 8px !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 10px !important;
    font-weight: 600 !important;
    color: #18442A !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12) !important;
    white-space: nowrap !important;
  }

  :global(.map-label::before) {
    display: none !important;
  }

  :global(.map-label--dest) {
    color: #45644A !important;
    border-color: rgba(69, 100, 74, 0.25) !important;
  }

  :global(.leaflet-attribution-flag) {
    display: none !important;
  }

  :global(.leaflet-control-attribution) {
    font-size: 9px !important;
    opacity: 0.5 !important;
  }

  @keyframes map-pulse {
    0%   { box-shadow: 0 0 0 0 currentColor; }
    70%  { box-shadow: 0 0 0 12px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }

  #hero-map {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Left-to-right gradient: opaque forest green → transparent */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        100deg,
        rgba(10, 26, 16, 0.92) 0%,
        rgba(10, 26, 16, 0.80) 30%,
        rgba(10, 26, 16, 0.45) 55%,
        rgba(10, 26, 16, 0.15) 75%,
        rgba(10, 26, 16, 0.05) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(10, 26, 16, 0.3) 0%,
        transparent 20%,
        transparent 80%,
        rgba(10, 26, 16, 0.4) 100%
      );
    pointer-events: none;
  }

  /* Content — left-aligned over the gradient */
  .hero__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    padding: 0;
  }

  .hero__content-inner {
    max-width: 1160px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2.5rem;
    max-width: 560px;
    margin-left: max(2.5rem, calc(50vw - 580px));
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

.hero__title {
    font-size: clamp(2.6rem, 4.5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    color: white;
    letter-spacing: -0.025em;
  }

  .hero__title em {
    font-style: normal;
    color: var(--sand);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.72);
    max-width: 440px;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2.2rem;
    background: var(--sand);
    color: var(--forest);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 50px;
    text-decoration: none;
    width: fit-content;
    transition: all 0.2s;
  }

  .hero__cta:hover {
    background: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
  }

  /* Floating cards — bottom-right of the viewport */
  .hero__cards {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero__card {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 0.85rem 1.2rem;
    border: 1px solid rgba(24, 68, 42, 0.1);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.14);
    min-width: 220px;
    max-width: 260px;
  }

  .hero__card-icon {
    width: 34px;
    height: 34px;
    background: rgba(24, 68, 42, 0.08);
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero__card strong {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #0c1c12;
    margin-bottom: 0.15rem;
  }

  .hero__card span {
    font-family: 'Raleway', sans-serif;
    font-size: 0.7rem;
    color: #888;
    line-height: 1.4;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent);
    animation: scroll-drop 1.8s ease-in-out infinite;
  }

  @keyframes scroll-drop {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
    50%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(1); transform-origin: top; opacity: 0; }
  }

  @media (max-width: 900px) {
    .hero__content-inner {
      margin-left: 2.5rem;
    }

    .hero__cards {
      right: 1.5rem;
      bottom: 5rem;
    }
  }

  @media (max-width: 640px) {
    .hero__cards {
      display: none;
    }

    .hero__overlay {
      background: rgba(10, 26, 16, 0.75);
    }

    .hero__content-inner {
      margin-left: 1.5rem;
      margin-right: 1.5rem;
    }
  }
</style>
