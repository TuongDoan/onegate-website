<footer class="footer" id="cta">
  <div class="footer__inner">
    <h2 class="footer__title">Talk to Us</h2>

    <div class="footer__info">
      <div class="footer__block">
        <p class="footer__label">Office</p>
        <p>1154 Vo Van Kiet, Ben Thanh Ward</p>
        <p>Ho Chi Minh City, Vietnam</p>
      </div>

      <div class="footer__block">
        <p><span class="footer__label">Tel</span> (+84) 0903 044 508</p>
        <p><span class="footer__label">Email</span> <a href="mailto:chris@onegate.trading">chris@onegate.trading</a></p>
        <p><span class="footer__label">Zalo</span> 0706 150 068</p>
      </div>

      <div class="footer__socials">
        <a href="#" aria-label="Facebook" class="footer__social">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="18" fill="#F3EDE3"/>
            <path d="M20.2 18.6h2.3l.4-2.9h-2.7v-1.9c0-.8.2-1.4 1.4-1.4h1.4v-2.6c-.7-.1-1.5-.2-2.3-.2-2.3 0-3.8 1.4-3.8 3.9v2.2H14v2.9h2.9v7.6h3.3v-7.6z" fill="#18442A"/>
          </svg>
        </a>
        <a href="#" aria-label="Twitter" class="footer__social">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="18" fill="#F3EDE3"/>
            <path d="M26.5 13.3c-.6.3-1.3.5-2 .6.7-.4 1.3-1.1 1.6-1.9-.7.4-1.5.7-2.3.9-.7-.7-1.6-1.2-2.7-1.2-2 0-3.7 1.6-3.7 3.7 0 .3 0 .6.1.8-3-.2-5.8-1.6-7.6-3.8-.3.5-.5 1.2-.5 1.9 0 1.3.6 2.4 1.7 3.1-.6 0-1.1-.2-1.6-.4 0 1.8 1.3 3.3 3 3.7-.3.1-.7.1-1 .1-.2 0-.5 0-.7-.1.5 1.5 1.9 2.6 3.5 2.6-1.3 1-2.9 1.6-4.7 1.6h-.9c1.7 1.1 3.7 1.7 5.8 1.7 7 0 10.8-5.8 10.8-10.8v-.5c.8-.5 1.4-1.2 1.9-2z" fill="#18442A"/>
          </svg>
        </a>
        <a href="#" aria-label="Instagram" class="footer__social">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="18" fill="#F3EDE3"/>
            <rect x="10" y="10" width="16" height="16" rx="4.5" stroke="#18442A" stroke-width="1.8" fill="none"/>
            <circle cx="18" cy="18" r="3.8" stroke="#18442A" stroke-width="1.8" fill="none"/>
            <circle cx="23" cy="13" r="1" fill="#18442A"/>
          </svg>
        </a>
      </div>

      <a href="mailto:chris@onegate.trading" class="footer__cta">TALK TO US</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #18442A;
    color: #F3EDE3;
    padding: 6rem 3.5rem 4rem;
  }

  .footer__inner {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
  }

  .footer__title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    font-weight: 400;
    color: #F3EDE3;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .footer__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    font-family: 'Montserrat', sans-serif;
    max-width: 520px;
  }

  .footer__block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__block p {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.55;
    color: #F3EDE3;
  }

  .footer__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243, 237, 227, 0.6);
    display: inline-block;
    min-width: 3.5rem;
    margin-right: 0.5rem;
  }

  p.footer__label {
    display: block;
    margin-bottom: 0.15rem;
  }

  .footer__block a {
    color: inherit;
    text-decoration: none;
  }

  .footer__block a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .footer__social {
    display: inline-flex;
    transition: transform 0.2s, opacity 0.2s;
  }

  .footer__social:hover {
    transform: translateY(-2px);
    opacity: 0.85;
  }

  .footer__cta {
    display: inline-block;
    align-self: flex-start;
    padding: 1rem 3rem;
    background: #F3EDE3;
    color: #18442A;
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    margin-top: 1.5rem;
    transition: background 0.2s, transform 0.15s;
  }

  .footer__cta:hover {
    background: #ffffff;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .footer { padding: 4rem 1.5rem 3rem; }
    .footer__inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
