---
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <svg width="30" height="30" viewBox="0 0 36 36" fill="none">
          <circle cx="18" cy="18" r="17" stroke="#E4DBC4" stroke-width="1.5" fill="none"/>
          <path d="M8 12 Q18 6 28 12" stroke="#E4DBC4" stroke-width="2.2" fill="none" stroke-linecap="round"/>
          <path d="M6 18 Q18 10 30 18" stroke="#E4DBC4" stroke-width="2.2" fill="none" stroke-linecap="round"/>
          <path d="M7 24 Q18 14 29 24" stroke="#E4DBC4" stroke-width="2.2" fill="none" stroke-linecap="round"/>
          <path d="M18 1 Q22 10 22 18 Q22 26 18 35" stroke="#E4DBC4" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M18 1 Q14 10 14 18 Q14 26 18 35" stroke="#E4DBC4" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        </svg>
        <div>
          <div class="footer__logo-name">ONE GATE</div>
          <div class="footer__logo-sub">GLOBAL TRADING</div>
        </div>
      </a>
      <p class="footer__tagline">Your gateway to smarter China sourcing.</p>
    </div>

    <div class="footer__col">
      <h4>Company</h4>
      <ul>
        <li><a href="#about">About Us</a></li>
        <li><a href="#solutions">Our Solutions</a></li>
        <li><a href="#cta">Contact</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Platform</h4>
      <ul>
        <li><a href="#">Gom Gom</a></li>
        <li><a href="#">Supplier Network</a></li>
        <li><a href="#">Documentation</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <span>© {new Date().getFullYear()} One Gate Global Trading. All rights reserved.</span>
    <div class="footer__legal">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0a1a10;
    color: rgba(255,255,255,0.75);
    padding: 5rem 2.5rem 2.5rem;
  }

  .footer__inner {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .footer__logo-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--sand);
  }

  .footer__logo-sub {
    font-family: 'Raleway', sans-serif;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--ocean);
  }

  .footer__tagline {
    font-family: 'Raleway', sans-serif;
    font-size: 0.88rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.38);
    max-width: 240px;
  }

  .footer__col h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 1.25rem;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer__col a {
    font-family: 'Raleway', sans-serif;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.48);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__col a:hover {
    color: var(--sand);
  }

  .footer__bottom {
    max-width: 1160px;
    margin: 2.25rem auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__bottom span {
    font-family: 'Raleway', sans-serif;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer__legal a {
    font-family: 'Raleway', sans-serif;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__legal a:hover {
    color: var(--sand);
  }

  @media (max-width: 700px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
